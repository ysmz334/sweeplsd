build/
build_*/
*.exe
*.obj
*.o
*.pdb

# Downloaded third-party debug-info converter (cv2pdb, GPL) used by
# tools/build_profile.bat to make the MinGW binary VS-profileable. Fetched
# locally, not vendored — see docs/profiling.md for how to obtain it.
tools/cv2pdb/
.vs/
.vscode/
.cache/
CMakeUserPresets.json

# FIFO-drop study visualiser output (large, regenerable via hls/tools/fifo_dropviz)
dropviz_out/

# Local corpus manifest for the overflow tools: absolute paths into the (not
# redistributed) Waseda dataset — machine-specific, keep on disk, never commit.
hls/tools/waseda150.txt

# HLS build artifacts (hls/)
hls/proj_sweeplsd_hls/
hls/logs/
vitis_hls.log
vitis-run.log

# RTL (phase 2) board build logs, images, and one-off synthesis experiments.
# ("build/" and "build_*/" above already cover build_rx/ and the synth_fe/be
# build outputs; these dirs are ad-hoc XST timing probes / demo renders.)
*.log
*.ppm
rtl/boards/atlys/demo_out/
rtl/boards/atlys/synth_core/
rtl/boards/atlys/synth_smoke/
rtl/hw_sim_out/

# Xilinx XAPP495 DVI reference design (Digilent/Xilinx app-note licensed):
# needed locally to build the Atlys board, but NOT redistributable in this
# repo — keep it on disk, never commit it.
rtl/boards/atlys/xapp495/

# Development retrospective notes (Japanese working material, kept local).
振り返り/

# Large golden-vector sets — regenerable with rtl/tools/dump_vectors (see
# rtl/DESIGN.md). vectors_big/ also dumps raw Waseda image pixels, which are
# not redistributed here. Only the small self-contained synthetic set
# (rtl/tb/vectors/, built from dump_vectors' own procedural images) is tracked.
rtl/tb/vectors_720p/
rtl/tb/vectors_big/
rtl/tb/vprof/

# Local diagnostic dumps and comparison renders — regenerable, and some derive
# from the non-redistributed Waseda photos. Keep on disk, never commit.
.compare150/
*.pgm
rtl/tb/rtl150/
rtl/tb/vectors_dbg*/
rtl/tb/*_burst.csv
rtl/tb/*_dropmask.txt
rtl/tb/*_recs_out.txt
rtl/tb/*.vvp
